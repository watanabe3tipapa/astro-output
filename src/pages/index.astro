---
import BlogLayout from '../layouts/BlogLayout.astro';
---

<BlogLayout title="Astro Output">
  <main style="max-width: 800px; width: 100%; padding: 2rem 1rem;">
    <h1>Astro Output</h1>
    <p>Markdown 記事を GitHub 風スタイルで表示するブログです。</p>
    <a href={`${import.meta.env.BASE_URL}posts/`} style="display: inline-block; margin-top: 1rem; padding: 0.5rem 1rem; background: #0969da; color: #fff; text-decoration: none; border-radius: 6px;">
      記事一覧を見る
    </a>
  </main>
</BlogLayout>
